# For local development (no Docker). With Docker Compose, ai-service is configured from the project root .env and docker-compose.yml (REDIS_URL, DOCS_DIR, CHROMA volume, etc.).
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5-nano
AI_HTTP_TIMEOUT=45

# RAG knowledge base (docs/ Markdown)
DOCS_DIR=./docs
RAG_TOP_K=5
CHROMA_PERSIST_DIR=./data/chroma

# Optional for local RAG cache (Docker sets REDIS_URL and RAG_CACHE_TTL_SECONDS from root .env)
REDIS_URL=redis://localhost:6379/0
# RAG_CACHE_TTL_SECONDS=300

# Response cache: when > 0, identical question+context responses are cached (reduces latency and cost).
# Example: 300 = 5 minutes. Set to 0 to disable.
# CACHE_TTL_SECONDS=300
