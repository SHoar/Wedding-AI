# Required for AI Q&A (ask feature). Get a key: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano
AI_HTTP_TIMEOUT=45
# Compose default when unset: redis://redis:6379/0
REDIS_URL=redis://redis:6379/0
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:8080
VITE_API_BASE_URL=/
VITE_API_PROXY_TARGET=http://localhost:3000
VITE_DEFAULT_WEDDING_ID=1

# Optional ai-service overrides (compose defaults shown)
# OPENAI_SUMMARIZATION_MODEL=
# OPENAI_QA_MODEL=
# CACHE_TTL_SECONDS=60
# RAG_CACHE_TTL_SECONDS=300
